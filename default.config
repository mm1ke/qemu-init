#################
# boot settings #
#################

# boot options (floppy, harddisk, cdrom, network)
#VM_BOOT_DEV="cdrom"
# path to the image file or cd
#VM_CDROM="/path/to/iso"

# using kernel+initrd
# VM_KERNEL & VM_INITRD must be set to use this feature
# VM_APPEND is optional
#VM_KERNEL=""
#VM_INITRD=""
#VM_APPEND=""

# boot message which gets printed on boot (on the host)
#VM_START_MESSAGE="
#	VM is booting
#"

##########################
# guest machine settings #
##########################

### guest system ###
# Default Value | description
# kvm   | select accelerator (kvm|xen|hax|...) (see: qemu-system-x86_64 -accel ?)
#VM_ACCEL="kvm"
# 512   | guest memory
VM_MEMORY="4G"
# 2     | number of cores
VM_SMP="cores=4,threads=1,sockets=1"
# de    | keyboard layout language
VM_LC="de"
# pc    | machine typ (see: qemu-system-x86_64 -machine ?)
VM_MACHINE="q35"
# host  | guest cpu settings (see: qemu-system-x86_64 -cpu ?)
#VM_CPU="host"
# 4     | number of usb redirctions ports
#VM_USB_REDIR="4"
# 4     | number of pcie ports
#VM_PCIE_PORTS="4"

######################
# guest gpu settings #
######################

# video card type: (std|cirrus|vmware|qxl|xenfb|tcx|cg3|virtio|none)
# GPU support works with venus, but requires VM_DISPLAY_MODE
VM_VGA="virtio"
# none  | display mode (spice-app|gtk|sdl|none)
#VM_DISPLAY_MODE="none"

##########################
# guest general settings #
##########################

### remote access ###
## enable:         true|false
## password:       default: empty
## listening ip:   default: host ip
## listening port: default port 5800/5900
#
# example: VM_REMOTE_ACCESS_SPICE="true;password;listening_ip;listening_port"
#
VM_REMOTE_ACCESS_SPICE="true"
#VM_REMOTE_ACCESS_VNC="false"

### guest network ###
## network_typ:    user|tap|bridge[DEFAULT] (required)
## mac_address:    default: random (base: 56:6E:17:XX:XX:XX)
## network_driver: e1000|rtl8139[DEFAULT]|virtio-net-pci
##  * `qemu-system-x86_64 -net nic,model=?` shows available devices
## bridge_dev:     required for tap interfaces
## tap_interface:  use specific tap interface (default auto generated)
#
#-- multiple interfaces are possible: VM_NETWORK1|VM_NETWORK2|... --#
# example: VM_NETWORK="network_typ;mac_address;network_driver;bridge_dev;tap_interface"
#
VM_NETWORK="bridge;56:6E:17:XX:XX:XX;virtio-net-pci;br0"

### guest harddisk ###
## harddisk:  path to image (required)
## interface: virtio|ide[DEFAULT]|scsi
## cache:     writethrough[DEFAULT]|writeback|none|unsafe
## aio:       threads[DEFAULT]|native
#
#-- multiple harddisks are possible: VM_HARDDISK1|VMHARDDISK2|... --#
# example: VM_HARDDISK2="harddisk;interface;cache;aio"
#
VM_HARDDISK="/path/to/harddisk;virtio"

### guest 9p filesystem sharing ###
## mount_tag:     mount tag name (required)
## path:          path which should made avaiable (required)
## security_mode: mapped|passthrough|none[DEFAULT]
## readonly:      on|off[DEFAULT]
#
#-- multiple 9p shares are possible: VM_9P_SHARE1|VM_9P_SHARE2|... --#
# example: VM_9P_SHARE2="mount_tag;path;security_mode;readonly"
#
#VM_9P_SHARE="name;/path/to/share"

### guest virtiofsd filesystem sharing ###
## mount_tag:    any name (required)
## path:         path which should be avaiable (required)
## caching mode: auto[DEFAULT]|always|never|metadata
#
#-- multiple vfsd shares are possible: VM_VFSD_SHARE1|VM_VFSD_SHARE2|... --#
# example: VM_VFSD_SHARE2="mount_tag;path"
#
#VM_VFSD_SHARE="name;/path/to/share"

### guest sound support ###
## audiodev: sdl[DEFAULT]|alsa|oss|none
##  * `qemu-system-x86_64 -audio help` for supported audiodevs
## device:   ich9-intel-hda[DEFAULT]|sb16|ac97|...
##  * `qemu-system-x86_64 -device ?` for suppored devices
#
#-- multiple devices are possible: VM_AUDIO1|VM_AUDIO2|... --#
# example: VM_AUDEO2="audiodev;device"
#
#VM_AUDIO="sdl;ich9-intel-hda"

### guest devices
## for a list of all possible devices see: `qemu-system-x86_64 -device ?`
#
#-- multiple devices are possible: VM_DEVICES1|VM_DEVICES2|... --#
# example: VM_DEVICES2="-device usb-tablet -device usb-mouse"
#
VM_DEVICES="-device usb-tablet"

###################
# guest features  #
###################

# Default Value | Description
# ON  | daemonize
#VM_ENABLE_DAEMONIZE="false"
# ON  | enable usb support
#VM_ENABLE_USB="false"
# ON  | virtio serial (clipboard sharing)
#VM_ENABLE_VIRTSERIAL="false"
# OFF | qemu-guest-agent
#VM_ENABLE_QGA="true"
# OFF | enable qemu machine protocol
#VM_ENABLE_QMP="true"
# OFF | enable TPM2 device
#VM_ENABLE_TPM2="true"
# OFF | enable snapshot mode
#VM_ENABLE_SNAPSHOTMODE="true"
# OFF | enable experimental in kernel accelerator
#VM_ENABLE_VHOST="true"
# OFF | enable virtio pmem
#VM_ENABLE_VPMEM="true"

#################
# host settings #
#################

# qemu binary to use, defaults to host arch (qemu-system-x86_64)
#VM_ARCH="x86_64"
# host user to start guest with (only required when running as root)
#VM_USER="nobody"

